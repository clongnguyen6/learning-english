# Shared environment contract for local development, CI, and future deployment.
#
# Rules:
# - Keep safe defaults and non-secret shape definitions here.
# - Inject real secrets via local `.env`, CI secrets, or deployment-specific config.
# - Frontend runtime vars must use the `VITE_` prefix; secrets must never.

APP_ENV=development
APP_PUBLIC_URL=http://localhost:5173
API_BASE_URL=http://localhost:8080

# Local PostgreSQL foundation for development and migrations.

POSTGRES_DB=learning_english
POSTGRES_USER=learning_english
POSTGRES_PASSWORD=learning_english_dev
POSTGRES_PORT=5432
POSTGRES_INITDB_ARGS=--encoding=UTF8

# Host-side connection string for tools that run on the machine.
DATABASE_URL=postgres://learning_english:learning_english_dev@localhost:5432/learning_english?sslmode=disable

# Container-side connection string for future app services in Compose.
DATABASE_URL_INTERNAL=postgres://learning_english:learning_english_dev@postgres:5432/learning_english?sslmode=disable

# Planned backend runtime contract.
# The backend shell must fail fast when required values are missing.
API_ADDR=:8080
LOG_LEVEL=info
REQUEST_ID_HEADER=X-Request-Id
CORS_ALLOWED_ORIGINS=http://localhost:5173
JWT_ISSUER=learning-english
JWT_AUDIENCE=learning-english-web
JWT_HS256_SECRET=
ACCESS_TOKEN_TTL=15m
REFRESH_TOKEN_TTL=720h
REFRESH_COOKIE_NAME=le_refresh
REFRESH_COOKIE_DOMAIN=
REFRESH_COOKIE_SECURE=false
REFRESH_COOKIE_SAME_SITE=lax
STORAGE_BACKEND=local
STORAGE_BUCKET=learning-english-local
STORAGE_REGION=us-east-1
STORAGE_ENDPOINT=
STORAGE_PUBLIC_BASE_URL=

# Planned frontend runtime contract.
# Only public, non-secret values belong here.
VITE_APP_ENV=development
VITE_APP_NAME=learning-english
VITE_APP_ORIGIN=http://localhost:5173
VITE_API_BASE_URL=http://localhost:8080/api/v1
